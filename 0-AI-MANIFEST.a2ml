; SPDX-FileCopyrightText: 2026 Jonathan D.A. Jewell (hyperpolymath)
;
; 0-AI-MANIFEST.a2ml — Universal AI entry point for Airborne Submarine Squadron
; Media-Type: application/a2ml

; THIS FILE MUST BE READ FIRST BY ALL AI AGENTS

(manifest
  (identity
    (name "airborne-submarine-squadron")
    (full-name "Airborne Submarine Squadron (ASS)")
    (version "0.4.0")
    (repo "https://github.com/hyperpolymath/airborne-submarine-squadron")
    (license "AGPL-3.0-or-later")
    (author "Jonathan D.A. Jewell <j.d.a.jewell@open.ac.uk>")
    (co-author "Joshua Jewell (JoshuaJewell)")
    (ownership "primary-owner: JoshuaJewell, admin: hyperpolymath"))

  (purpose
    "Sopwith-inspired flying submarine arcade game. Free-flight 2D arcade with
     submarine, aircraft, ship and space mechanics. AffineScript compiled to WASM
     as physics co-processor; Gossamer v2 JS engine is the current playable frontend.
     Standalone AGPL repo — exception to PMPL, co-developed with son.")

  (context-tiers
    (tier-0 "Always load: this file + .claude/CLAUDE.md")
    (tier-1 "Load if working on code: README.adoc, EXPLAINME.adoc, Justfile")
    (tier-2 "Load on demand: .machine_readable/STATE.scm, docs/")
    (tier-3 "Never load unless asked: gossamer/app_gossamer.js (7300+ lines), build/"))

  (canonical-locations
    (ai-manifest     "0-AI-MANIFEST.a2ml"                    "THIS FILE")
    (ai-instructions ".claude/CLAUDE.md"                     "Claude-specific patterns")
    (state           ".machine_readable/STATE.scm")
    (meta            ".machine_readable/META.scm")
    (ecosystem       ".machine_readable/ECOSYSTEM.scm")
    (web-entry       "index.html"                            "Root game entry — no redirect")
    (game-engine     "gossamer/app_gossamer.js"              "Gossamer v2 JS engine")
    (desktop-entry   "gossamer/index_gossamer.html"          "Gossamer desktop HTML")
    (as-source       "src/main.as"                           "Canonical AffineScript source")
    (wasm-dist       "dist/airborne-submarine-squadron.wasm" "Tracked release artifact")
    (launcher        "launcher.sh"                           "Unified launcher")
    (build-script    "build.sh"                              "AffineScript to WASM build"))

  (architecture
    (js-engine  "gossamer/app_gossamer.js"           "Full game at 60fps — current playable")
    (wasm-coproc "build/airborne-final-working.wasm" "AffineScript physics co-processor")
    (tray       "tray/src/main.rs"                   "Rust system tray (ksni)")
    (ffi        "ffi/zig/"                           "Zig FFI layer")
    (ports      "browser:6860 gossamer-fallback:6870-6879"))

  (critical-invariants
    (rule "AGPL-3.0-or-later only — do NOT change license or relicense")
    (rule "Standalone git repo — do NOT merge into any monorepo")
    (rule "No TypeScript — use vanilla JS or AffineScript only")
    (rule "No Tauri or Electron — browser plus ksni tray binary only")
    (rule "No npm, bun, pnpm, yarn — Deno only for JS runtime")
    (rule "No Node.js — Deno only")
    (rule "SCM files MUST be in .machine_readable/ — never in root")
    (rule "src/main.as is the ONLY canonical AffineScript source")
    (rule "gossamer/app_gossamer.js is the current game engine — do not replace"))

  (lifecycle
    (on-enter
      (step "Read THIS file first")
      (step "Read .machine_readable/STATE.scm for current status and blockers"))
    (on-exit
      (step "Update .machine_readable/STATE.scm with any progress made")
      (step "Commit and push — full git cycle")))

  (format-meta
    (version "2.1.0")
    (media-type "application/a2ml")
    (created "2026-01-30")
    (last-updated "2026-04-03")
    (maintained-by "Jonathan D.A. Jewell / hyperpolymath")
    (protocol "https://github.com/hyperpolymath/0-ai-gatekeeper-protocol")))
