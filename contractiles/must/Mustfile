# Mustfile - declarative state contract for Airborne Submarine Squadron
# See: https://github.com/hyperpolymath/mustfile

version: 1

metadata:
  name: airborne-submarine-squadron-contract
  spec: v0.5.0
  description: "Invariant checks for game build, SCM files, and project health."
  primary-owner: "JoshuaJewell (owner)"
  primary-admin: "hyperpolymath (project admin)"

parameters:
  port: "6880"

checks:
  - name: scm-files-exist
    description: "Machine-readable SCM files must exist in .machine_readable/"
    run: "test -f .machine_readable/STATE.scm && test -f .machine_readable/META.scm && test -f .machine_readable/ECOSYSTEM.scm"

  - name: ai-manifest-exists
    description: "AI manifest must exist at root"
    run: "test -f 0-AI-MANIFEST.a2ml"

  - name: gossamer-parses
    description: "Gossamer game engine JS must parse without syntax errors"
    run: "deno eval \"import('file://' + Deno.cwd() + '/gossamer/app_gossamer.js').catch(e => { if (!e.message.includes('document')) { console.error(e); Deno.exit(1); } })\""

  - name: tray-compiles
    description: "Rust tray binary must compile"
    run: "cd tray && cargo check"

  - name: deno-files-check
    description: "Deno JS files must type-check"
    run: "deno check run_wasm.js && deno check test_verisimdb_simple.js"

  - name: well-known-present
    description: ".well-known directory must have security.txt"
    run: "test -f .well-known/security.txt"

  - name: license-correct
    description: "LICENSE must be AGPL-3.0-or-later"
    run: "head -1 LICENSE | grep -q 'GNU AFFERO'"

  - name: no-node-references
    description: "No Node.js or npm references in active code"
    run: "! grep -r 'require(' gossamer/app_gossamer.js run_wasm.js"
