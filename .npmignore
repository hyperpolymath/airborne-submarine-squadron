# npm ignore file for airborne-submarine-squadron

# Ignore git and version control files
.git
.gitignore
.gitattributes

# Ignore build artifacts and temporary files
*.tar.gz
*.zip
*.bak
*.backup

# Ignore backup directory
.backup/

# Ignore node_modules
node_modules/

# Ignore logs and temporary files
*.log
*.tmp

# Ignore examples
examples/

# Ignore desktop-specific files
desktop/

# Ignore release files
release/

# Ignore git-related files
.github/

# Ignore machine readable files
.machine_readable/

# Ignore contractiles
contractiles/

# Ignore ffi
ffi/

# Ignore specific documentation files (keep README.md)
*.adoc
docs/
notes/
*.txt

# Keep these specific files that are in the files array
gossamer/
tray/
build/
dist/
src/
launcher.sh
install.sh
build.sh
run_wasm.js
README.md
package.json
.npmignore